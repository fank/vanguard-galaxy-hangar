# Build artifacts
bin/
obj/
*.user

# IDE
.vs/
.idea/

# Plugin's compile-time references
# - Assembly-CSharp.dll: publicized STUB of the game's assembly (method
#   signatures only, no IL bodies). Committed so CI can build.
# - UnityEngine.UI.dll / Unity.TextMeshPro.dll: publicized Unity runtime
#   stubs, required for UI patches (Toggle, TMP_Text). Also committed.
# Regenerate all three after game updates via:
#   assembly-publicizer --strip <game>/Assembly-CSharp.dll     -o VGHangar/libs/Assembly-CSharp.dll
#   assembly-publicizer --strip <game>/UnityEngine.UI.dll      -o VGHangar/libs/UnityEngine.UI.dll
#   assembly-publicizer --strip <game>/Unity.TextMeshPro.dll   -o VGHangar/libs/Unity.TextMeshPro.dll
# --strip is REQUIRED: it replaces every method body with `throw null;` so the
# committed DLL carries only type metadata — no game logic, no Unity runtime
# code. Running the tool WITHOUT --strip leaves the full proprietary IL intact,
# which we can't legally redistribute.
libs/*.dll
libs/*.pdb
!libs/Assembly-CSharp.dll
!libs/UnityEngine.UI.dll
!libs/Unity.TextMeshPro.dll
!libs/0Harmony.dll
!libs/BepInEx.dll
!libs/UnityEngine.CoreModule.dll
!libs/UnityEngine.dll
!libs/UnityEngine.InputModule.dll


# Local overrides
*.local

# Release staging artifacts produced by the release workflow
dist/
